# Copy to .env and customize.
COFISWARM_FHS_ROOT=~/cofiswarm/fhs
COFISWARM_REPOS_ROOT=~/cofiswarm/repos
COFISWARM_PROFILE=16gb
# Go toolchain (if go not on PATH): export PATH="$HOME/.local/go/bin:$PATH"
# mlx-env may set CC to Homebrew LLVM; for pure-Go builds use: CGO_ENABLED=0 make build-dispatch
MATRIX_BIND_HOST=127.0.0.1
MATRIX_CASCADE_AGENT_DEADLINE_SECS=90
RAG_DSN=postgresql://matrix:matrix@127.0.0.1:5433/matrix_rag
# Required for UI Configure (llama agents):
MATRIX_LLAMA_SERVER=/Users/caribou/llama.cpp/build/bin/llama-server
# Detect: ./scripts/detect-llama-server.sh
